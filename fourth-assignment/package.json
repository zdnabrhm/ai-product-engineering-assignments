{
  "name": "fourth-assignment",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @fourth-assignment/db db:generate",
    "db:migrate": "pnpm --filter @fourth-assignment/db db:migrate",
    "db:deploy": "pnpm --filter @fourth-assignment/db db:deploy",
    "db:studio": "pnpm --filter @fourth-assignment/db db:studio",
    "db:format": "pnpm --filter @fourth-assignment/db db:format"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "turbo": "^2.10.5",
    "typescript": "~7.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.13.1"
}
