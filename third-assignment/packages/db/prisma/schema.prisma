generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoadmapCategory {
  LEARNING
  CAREER
  EVENT
  PROJECT
}

enum RoadmapStatus {
  QUEUED
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

model Roadmap {
  id               String          @id @default(cuid())
  category         RoadmapCategory
  goal             String
  currentSituation String
  targetDate       DateTime
  constraints      String
  status           RoadmapStatus   @default(QUEUED)
  plan             Json?
  result           Json?
  sources          Json            @default("[]")
  rejectionReason  String?
  error             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}
